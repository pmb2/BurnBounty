{
  "name": "burnbounty-poc",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "contracts:compile": "tsx scripts/compile.ts",
    "contracts:deploy": "tsx scripts/deploy.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:migrate:test": "cross-env AUTH_TEST_USE_INMEM_DB=true tsx scripts/db-migrate.ts",
    "test:flow": "tsx scripts/test-flow.ts",
    "test:demo-flow": "tsx scripts/demo-showcase-flow.ts",
    "test:auth": "cross-env AUTH_TEST_USE_INMEM_DB=true node --import tsx --test --test-concurrency=1 tests/auth/*.test.ts",
    "release:auth-gate": "npm run db:migrate:test && npm run test:auth && npm run typecheck && npm run build",
    "gen:cards": "tsx scripts/generate-card-assets.ts",
    "live:up": "docker compose -f deploy/traefik/docker-compose.existing-traefik.yml --env-file deploy/traefik/.env.live up -d --build",
    "live:down": "docker compose -f deploy/traefik/docker-compose.existing-traefik.yml --env-file deploy/traefik/.env.live down"
  },
  "dependencies": {
    "@cashscript/sdk": "npm:cashscript@^0.12.1",
    "@metamask/eth-sig-util": "^8.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/supabase-js": "^2.52.0",
    "bitcore-lib-cash": "^10.8.6",
    "canvas-confetti": "^1.9.4",
    "cashscript": "^0.12.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.6.3",
    "gsap": "^3.14.2",
    "lenis": "^1.3.19",
    "lucide-react": "^0.511.0",
    "next": "15.3.1",
    "pg": "^8.20.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "scrypt-js": "^3.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "three": "^0.183.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.3.1",
    "pg-mem": "^3.0.14",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
